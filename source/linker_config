MEMORY {
    INIT: start=0x00, size=0x20, type=ro;
    ROM: start=0x20, size=0x1ff0, type=ro;
    RAM: start=0x2000, size=0xdfed, type=rw;
    SERIAL: start=0xffed, size=0x3, type=rw;
    VEC: start=0xfff0, size=0x10, type=ro;
}

SEGMENTS {
    SEG_INIT: load=INIT;
    SEG_GET_CHAR: load=ROM;
    SEG_PUT_CHAR: load=ROM;
    SEG_ECHO: load=ROM;
    SEG_WOZ: load=ROM;
    SEG_CONV: load=ROM;
}
